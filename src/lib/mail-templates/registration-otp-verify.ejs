<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8" />
    <title>Smart HMS - OTP Verification</title>
</head>

<body style="margin:0; padding:0; background:#f3f4f6; font-family:Arial, Helvetica, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
            <td align="center" style="padding:40px 0;">
                <table width="600" cellpadding="0" cellspacing="0"
                    style="background:#ffffff; border-radius:8px; padding:32px;">

                    <!-- HEADER -->
                    <tr>
                        <td style="text-align:center; border-bottom:1px solid #e5e7eb; padding-bottom:20px;">
                            <h1 style="margin:0; color:#1f2937; font-size:24px;">
                                Smart HMS
                            </h1>
                            <p style="margin:6px 0 0; color:#6b7280; font-size:14px;">
                                Hospital Management System
                            </p>
                            <h3 style="margin-top:16px; color:#2563eb; font-weight:600;">
                                Account Verification
                            </h3>
                        </td>
                    </tr>

                    <!-- BODY -->
                    <tr>
                        <td style="padding-top:24px; color:#374151; font-size:15px;">
                            <p>Hello,</p>

                            <p>
                                You are attempting to verify your
                                <strong>Smart HMS</strong>
                                <%= role ? `(${role})` : "" %> account.
                            </p>

                            <p>
                                Please use the OTP below to complete your verification:
                            </p>

                            <div style="text-align:center; margin:30px 0;">
                                <span style="
                    display:inline-block;
                    background:#f1f5f9;
                    color:#1f2937;
                    font-size:28px;
                    letter-spacing:6px;
                    padding:14px 26px;
                    border-radius:8px;
                    font-weight:bold;">
                                    <%= otp %>
                                </span>
                            </div>

                            <p style="text-align:center; font-size:14px; color:#6b7280;">
                                ⏳ This OTP will expire at
                                <strong>
                                    <%= expiresIn %>
                                </strong>
                            </p>

                            <p style="margin-top:24px; font-size:14px; color:#6b7280;">
                                If you did not request this verification, you can safely ignore this email.
                            </p>

                            <p style="margin-top:28px;">
                                Regards,<br />
                                <strong>Smart HMS Security Team</strong>
                            </p>
                        </td>
                    </tr>

                    <!-- FOOTER -->
                    <tr>
                        <td style="border-top:1px solid #e5e7eb; padding-top:16px;
              font-size:12px; color:#9ca3af; text-align:center;">
                            © <%= new Date().getFullYear() %> Smart HMS – Hospital Management System
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>
</body>

</html>